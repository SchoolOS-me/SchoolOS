# Backend local environment example
# Copy to .env and adjust values for your machine.

ENVIRONMENT_NAME=local
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-local-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (used by config/settings.py)
POSTGRES_DB=neondb
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Cache / broker
REDIS_CONNECTION=redis://127.0.0.1:6379

# CORS / CSRF for local frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=5
ACCESS_TOKEN_LIFETIME_DAYS=7

# Optional integrations
OPENAI_API_KEY=
STRIPE_ENABLED=false
STRIPE_LIVE_SECRET_KEY=
STRIPE_TEST_SECRET_KEY=
DJSTRIPE_WEBHOOK_SECRET=

# Email (dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_FROM_ADDRESS=from@example.org
EMAIL_REPLY_ADDRESS=from@example.org

# Misc
HASHID_FIELD_SALT=change-me-hashid-salt
PARENT_HOST=
WORKERS_EVENT_BUS_NAME=local-workers
LAMBDA_TASKS_BASE_HANDLER=common.tasks.LambdaTask
