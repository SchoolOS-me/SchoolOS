{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django Backend Debug",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/backend/manage.py",
      "args": ["runserver", "0.0.0.0:8000"],
      "django": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}/packages/backend",
      "envFile": "${workspaceFolder}/packages/backend/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Frontend Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/packages/frontend"
    }
  ]
}
